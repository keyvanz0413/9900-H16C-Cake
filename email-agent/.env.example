# LLM Provider
# Option A: OpenOnion managed models
OPENONION_API_KEY=

# Option B: your own provider key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Agent model
# Examples:
# AGENT_MODEL=co/claude-sonnet-4-5
# AGENT_MODEL=gpt-4.1-mini
AGENT_MODEL=co/claude-sonnet-4-5
AGENT_ADDRESS=

# Choose one provider
LINKED_GMAIL=true
LINKED_OUTLOOK=false

# Gmail OAuth
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_TOKEN_EXPIRES_AT=
GOOGLE_SCOPES=gmail.send,gmail.readonly,gmail.modify,calendar
GOOGLE_EMAIL=

# Outlook OAuth
MICROSOFT_ACCESS_TOKEN=
MICROSOFT_REFRESH_TOKEN=
MICROSOFT_TOKEN_EXPIRES_AT=
MICROSOFT_SCOPES=
MICROSOFT_EMAIL=
